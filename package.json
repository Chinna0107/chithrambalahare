{
  "name": "tolly-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "crawl": false,
    "include": [
      "/",
      "/movie-news",
      "/reviews",
      "/box-office",
      "/about"
    ],
    "headless": true,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "inlineCss": false
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",

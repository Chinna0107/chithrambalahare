    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "axios": "^1.18.0",
    "framer-motion": "^12.40.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.20.0",
    "react": "^19.2.6",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.6",
